# Supabase Configuration
# ⚠️ IMPORTANTE: Reemplaza estos valores con tus credenciales reales de Supabase
# Las puedes encontrar en: https://supabase.com/dashboard → Tu Proyecto → Settings → API

# URL de tu proyecto Supabase (termina con .supabase.co)
VITE_SUPABASE_URL=https://tu-proyecto-id.supabase.co

# Clave anónima (anon public key)
VITE_SUPABASE_ANON_KEY=tu-clave-anonima-aqui